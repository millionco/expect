{
  "name": "@expect/recorder",
  "version": "0.0.1",
  "private": true,
  "files": [
    "dist",
    "viewer"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
