{
  "name": "@expect/recorder",
  "version": "0.0.1",
  "private": true,
  "files": [
    "dist",
    "viewer"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build:viewer": "vp build --config viewer/vite.config.ts",
    "build": "vp pack && pnpm build:viewer",
    "dev": "vp pack --watch",
    "lint": "vp lint && tsc --noEmit",
    "format": "vp fmt",
    "format:check": "vp fmt --check",
    "check": "vp check",
    "test": "vp test run --passWithNoTests",
    "test:watch": "vp test",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@effect/atom-react": "4.0.0-beta.35",
    "@effect/platform-node": "4.0.0-beta.35",
    "@expect/shared": "workspace:*",
    "@posthog/rrweb": "^0.0.50",
    "effect": "4.0.0-beta.35"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^22.15.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shadcn": "^3.8.5",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.7.0",
    "vite": "^7.3.1"
  }
}
