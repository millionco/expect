    "version": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@voidzero-dev/vite-plus-core": "latest",
    "turbo": "^2.8.17",
    "typescript": "^5.7.0",
    "vite-plus": "^0.1.12"
  },
  "packageManager": "pnpm@10.29.1"
}
