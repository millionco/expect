{
  "name": "expect",
  "private": true,
  "license": "FSL-1.1-MIT",
  "scripts": {
    "everything": "pnpm run build && pnpm run lint && pnpm run typecheck && pnpm run format && pnpm run check && pnpm run test",
    "dev": "turbo dev --filter='!./playground/*'",
    "build": "turbo build --filter='!./playground/*'",
    "lint": "turbo lint --filter='!./playground/*'",
    "lint:fix": "turbo lint --filter='!./playground/*' -- --fix",
    "typecheck": "turbo run typecheck",
    "format": "turbo format --filter='!./playground/*'",
    "format:check": "turbo format --filter='!./playground/*' -- --check",
    "check": "turbo check --filter='!./playground/*'",
    "test": "turbo test --filter='!./playground/*'",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@typescript/native-preview": "7.0.0-dev.20260319.1",
    "@voidzero-dev/vite-plus-core": "^0.1.14",
    "husky": "^9.1.7",
    "turbo": "^2.8.17",
    "typescript": "^5.7.0",
    "vite-plus": "^0.1.14"
  },
  "packageManager": "pnpm@10.29.1"
}
